generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id @default(cuid())
  name              String
  email             String       @unique
  password          String
  verifyOtp         String       @default("")
  verifyOtpExpireAt BigInt       @default(0)
  isAccountVerified Boolean      @default(false)
  resetOtp          String       @default("")
  resetOtpExpireAt  BigInt       @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  role              Role         @default(USER)
  image             String?
  notices           Notice[]
  winnerLists       WinnerList[]

  @@map("users")
}

model Notice {
  id          String         @id @default(cuid())
  title       String
  content     String?        @db.Text
  category    NoticeCategory @default(LTM)
  authorId    String
  filePath    String?
  status      Status         @default(active)
  publishDate DateTime?
  lastDate    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tableData   String?        @db.LongText
  type        NoticeType     @default(FILE)
  year        String?
  lotteryDate DateTime?
  createdBy   User           @relation(fields: [authorId], references: [id], onDelete: NoAction)

  @@index([createdAt(sort: Desc)])
  @@index([authorId], map: "notices_authorId_fkey")
  @@map("notices")
}

model WinnerList {
  id          String    @id @default(cuid())
  title       String
  content     String?   @db.Text
  authorId    String
  filePath    String?
  status      Status    @default(active)
  publishDate DateTime?
  lastDate    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User      @relation(fields: [authorId], references: [id], onDelete: NoAction)

  @@index([createdAt(sort: Desc)])
  @@index([authorId], map: "winner_lists_authorId_fkey")
  @@map("winner_lists")
}

enum Role {
  ADMIN
  USER
}

enum NoticeType {
  FILE
  TEXT
  TABLE
}

enum NoticeCategory {
  LTM
  OTM
  LOTTERY_PENDING
  LOTTERY_RESULT
}

enum Status {
  active
  inactive
}
